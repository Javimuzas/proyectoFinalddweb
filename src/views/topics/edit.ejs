<section class="form-card">
  <h1>Editar tema</h1>
  <form action="/topics/<%= topic.id %>/edit" method="POST">
    <label>Tema
      <input type="text" name="title" maxlength="120" required value="<%= topic.title %>">
    </label>
    <label>Puesto 1
      <input type="text" name="item_one" maxlength="120" required value="<%= topic.item_one %>">
    </label>
    <label>Puesto 2
      <input type="text" name="item_two" maxlength="120" required value="<%= topic.item_two %>">
    </label>
    <label>Puesto 3
      <input type="text" name="item_three" maxlength="120" required value="<%= topic.item_three %>">
    </label>
    <button class="button" type="submit">Guardar</button>
  </form>
</section>
